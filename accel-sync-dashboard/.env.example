# Base URL of the API (no trailing slash)
VITE_API_BASE_URL=http://localhost:3000

# Optional comma-separated list of user IDs to display.
# Leave unset to show users with journal entries or accel count data in the
# last 7 days.
# VITE_USER_IDS=123,456,789

# User ID used in the ActiGraph comparison view
VITE_ACTIGRAPH_USERID=123

# Optional: API key if your API requires it
# VITE_API_KEY=your_api_key
